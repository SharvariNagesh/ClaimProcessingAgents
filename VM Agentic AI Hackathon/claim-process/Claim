if selected_claim:
    if st.button('⚡ PROCESS CLAIM DETAILS'):
        try:
            s3 = boto3.client('s3', region_name=aws_region)
            result = s3.get_object(Bucket=bucket_name, Key=selected_claim)
            pdf_data = result['Body'].read()
            pdf_reader = PdfReader(io.BytesIO(pdf_data))
            full_text = '\n'.join([page.extract_text() or '' for page in pdf_reader.pages])

            if not full_text.strip():
                st.warning('The selected PDF contains no extractable text.')
            else:
                summary = full_text.strip().replace('\r', '\n')
                summary = '\n'.join([line for line in summary.split('\n') if line.strip()])
                short_summary = summary[:900] + ('...' if len(summary) > 900 else '')

                st.session_state.processed = True
                st.session_state.claim_text = full_text
                st.session_state.claim_summary = short_summary
                st.session_state.claim_name = selected_claim
                st.session_state.claim_status = 'Approved'
                st.session_state.claim_pages = len(pdf_reader.pages)
                st.session_state.email_drafted = False
                st.session_state.email_sent = False
                st.success('Claim PDF loaded, analyzed, and approved successfully.')
        except Exception as exc:
